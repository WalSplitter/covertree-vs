<UserControl x:Class="CoverTree.VS.ToolWindow.CoverTreeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CoverTree.VS.ToolWindow"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="TreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </UserControl.Resources>
    <DockPanel Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}">
        <!-- Toolbar -->
        <DockPanel DockPanel.Dock="Top" Margin="6,4,6,2">
            <Button DockPanel.Dock="Right" Content="&#x21BB;" Width="22" Height="22"
                    ToolTip="Refresh Coverage" Click="OnRefreshClick"
                    Background="Transparent" BorderThickness="1"
                    Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
            <TextBlock Text="{Binding OverallPctDisplay}" VerticalAlignment="Center"
                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
                       FontWeight="SemiBold"/>
        </DockPanel>

        <!-- Status line -->
        <TextBlock DockPanel.Dock="Top" Text="{Binding StatusText}"
                   Margin="6,0,6,4" FontSize="11"
                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"/>

        <!-- Tree -->
        <TreeView ItemsSource="{Binding Items}"
                  Background="Transparent" BorderThickness="0"
                  MouseDoubleClick="OnTreeDoubleClick"
                  ItemContainerStyle="{StaticResource TreeViewItemStyle}">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type local:CoverageFileItem}"
                                          ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="1,1,2,1">
                        <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}"
                                 Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
                                   ToolTip="{Binding Tooltip}"/>
                        <TextBlock Text="{Binding PctDisplay}" Margin="6,0,0,0" FontSize="10"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </DockPanel>
</UserControl>
